# Bancos de dados — NÃO versionar no git (grandes demais para o GitHub).
# Backup fica no Google Drive via rclone (ver README).
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Artefatos de sistema / editor
.DS_Store
*.swp
.harness/sync-cache.json

# Bytecode Python (regenerável)
__pycache__/
*.pyc

# Spike de flexões — artefatos gerados e ambiente local (o artefato StarDict
# contém conteúdo do Aurélio, uso estritamente pessoal: jamais versionar)
spike/*/dist/
spike/*/.venv/
spike/*/medicao-geracao.txt
spike/*/geracao-stdout.txt
